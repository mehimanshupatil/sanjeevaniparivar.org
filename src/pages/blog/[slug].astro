---
import Layout from "@/layouts/Layout.astro";
import BlogPostPage from "@/components/BlogPostPage";
import { getCollection } from 'astro:content';
import { marked } from 'marked';
import "@/styles/global.css";

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id } }));
}

const { slug } = Astro.params;
const posts = await getCollection('blog');
const post = posts.find((p) => p.id === slug);

if (!post) return Astro.redirect('/blog');

const bodyHtml = marked.parse(post.body ?? '') as string;

const postProps = {
  slug:     post.id,
  title:    post.data.title,
  excerpt:  post.data.excerpt,
  author:   post.data.author,
  date:     post.data.date,
  kshetra:  post.data.kshetra,
  bodyHtml,
  image:    post.data.image ?? null,
};

const canonicalUrl = new URL(`/blog/${post.id}`, 'https://sanjeevaniparivar.org').href;
const imageUrl = post.data.image
  ? new URL(post.data.image, 'https://sanjeevaniparivar.org').href
  : 'https://sanjeevaniparivar.org/assets/og-image.svg';

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.excerpt,
  image: imageUrl,
  datePublished: post.data.date,
  author: {
    "@type": "Organization",
    name: post.data.author,
    url: "https://sanjeevaniparivar.org",
  },
  publisher: {
    "@type": "Organization",
    name: "Sanjeevani Parivar",
    url: "https://sanjeevaniparivar.org",
    logo: {
      "@type": "ImageObject",
      url: "https://sanjeevaniparivar.org/assets/logo.png",
    },
  },
  mainEntityOfPage: { "@type": "WebPage", "@id": canonicalUrl },
  inLanguage: "mr",
  keywords: ["संजीवनी परिवार", post.data.kshetra, "वसई", "समाजकार्य"],
};
---

<Layout
  title={`${post.data.title} | संजीवनी परिवार`}
  description={post.data.excerpt}
  ogImage={post.data.image ?? undefined}
  ogImageAlt={post.data.title}
  ogType="article"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <BlogPostPage post={postProps} client:idle />
</Layout>
