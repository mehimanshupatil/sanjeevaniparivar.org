---
/**
 * index.astro — Landing page
 *
 * Static generation (output: 'static' in astro.config.mjs).
 * The React <App /> island is hydrated client-side (client:load)
 * so language switching works without a server.
 *
 * For future pages: duplicate this file, add a new Astro page
 * and import the relevant React section components.
 */
import Layout from '@/layouts/Layout.astro';
import App from '@/components/App';
import '@/styles/global.css';
---

<Layout
  title="संजीवनी परिवार | Sanjeevani Parivar — ध्यास परिवर्तनाचा"
  description="Sanjeevani Parivar is a leading social organization from Vasai working in Education, Environment, Health & Enlightenment for 31+ years."
>
  <!--
    client:load → React hydrates immediately on page load.
    Language is persisted in localStorage so the user's choice
    survives page refreshes.
  -->
  <App client:load />
</Layout>
